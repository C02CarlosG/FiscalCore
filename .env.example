# Backend
# DATABASE_URL: en desarrollo con `docker compose up -d db` puedes omitirlo
# (este es exactamente el valor por defecto del código). Solo es obligatorio
# en producción (Railway lo inyecta automáticamente al vincular PostgreSQL).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/fiscalcore

# Secreto para firmar los JWT. CÁMBIALO en producción.
JWT_SECRET=cambia-esto-en-produccion

# Seed inicial del admin (se crea solo si la base no tiene usuarios).
# Opcional: si los omites se usan estos mismos valores por defecto.
SEED_ADMIN_EMAIL=admin@fiscalcore.mx
SEED_ADMIN_PASSWORD=Admin2024!

# Frontend (Vite): solo para el build de producción (p. ej. Vercel).
# En desarrollo NO se necesita: vite.config.mjs hace proxy /api -> http://localhost:8000.
VITE_API_URL=
